# =================================================================
# .htaccess para Vue.js - Universidad Pública de El Alto
# Producción - Carrera de Medicina
# =================================================================

# ✅ Activar módulo de reescritura
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Redirigir todo a index.html (Vue Router en modo history)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^.*$ /index.html [L,QSA]
</IfModule>

# =================================================================
# 🔒 HEADERS DE SEGURIDAD (Obligatorio para OWASP ZAP)
# =================================================================

<IfModule mod_headers.c>
  # ✅ Prevenir Clickjacking
  Header always set X-Frame-Options "DENY"
  
  # ✅ Prevenir MIME sniffing
  Header always set X-Content-Type-Options "nosniff"
  
  # ✅ Prevenir XSS reflejado
  Header always set X-XSS-Protection "1; mode=block"
  
  # ✅ Controlar información de referencia
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  
  # ✅ Ocultar tecnología del servidor (X-Powered-By)
  Header unset X-Powered-By
  Header unset Server
  
  # ✅ Content-Security-Policy (Ajustado para tu API y recursos)
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com; img-src 'self' https:  blob:; font-src 'self' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.gstatic.com; frame-src 'self' https://www.youtube.com https://www.google.com https://maps.google.com; connect-src 'self' https://apiadministrador.upea.bo https://maps.googleapis.com; form-action 'self'; frame-ancestors 'none'; base-uri 'self';"
  
  # ✅ Permissions-Policy (Características del navegador)
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=()"
  
  # ✅ Cache-Control para HTML (no cachear)
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

# =================================================================
# 🚀 CACHE PARA ASSETS ESTÁTICOS (Mejora performance)
# =================================================================

<IfModule mod_expires.c>
  ExpiresActive On
  
  # Imágenes: 1 año
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  
  # Fuentes: 1 año
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  
  # CSS y JS: 1 mes (para permitir actualizaciones)
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
</IfModule>

# Cache-Control alternativo si mod_expires no está disponible
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|png|jpg|jpeg|gif|svg|webp|woff|woff2|ttf|eot|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# =================================================================
# 🔐 COMPRESIÓN GZIP (Mejora velocidad de carga)
# =================================================================

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/woff
  AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# =================================================================
# 🚫 PROTECCIÓN DE ARCHIVOS SENSIBLES
# =================================================================

# Denegar acceso a archivos ocultos (.git, .env, etc.)
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# Denegar acceso a archivos de configuración
<FilesMatch "\.(env|log|sql|sh|bat|cmd|ini|conf|config)$">
  Require all denied
</FilesMatch>

# Denegar listado de directorios
Options -Indexes

# =================================================================
# 🔒 HTTPS FORZADO (Redirigir HTTP → HTTPS)
# =================================================================

<IfModule mod_ssl.c>
  # Si no es HTTPS, redirigir
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# HSTS (HTTP Strict Transport Security) - Solo si ya tienes SSL activo
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# =================================================================
# ✅ MIME TYPES CORRECTOS
# =================================================================

<IfModule mod_mime.c>
  AddType application/javascript js
  AddType text/css css
  AddType image/svg+xml svg
  AddType application/font-woff woff
  AddType application/font-woff2 woff2
  AddType application/manifest+json webmanifest
</IfModule>

# =================================================================
# 🛡️ PREVENCIÓN DE ATAQUES COMÚNES
# =================================================================

# Bloquear acceso a archivos sensibles de Vue
<FilesMatch "(package\.json|vue\.config\.js|babel\.config\.js|tsconfig\.json)$">
  Require all denied
</FilesMatch>

# Limitar tamaño de petición (previene DoS básico)
LimitRequestBody 10485760